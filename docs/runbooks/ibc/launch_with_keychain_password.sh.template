#!/bin/bash
# Launch IBC with password from macOS keychain — template
# Install: cp to ~/ibc/scripts/launch_with_keychain_password.sh && chmod +x
set -euo pipefail
IBC_HOME="${IBC_HOME:-$HOME/ibc}"
IBKR_PASSWORD="$(security find-generic-password -a "${IBKR_KEYCHAIN_USER:-$USER}" -s ibkr_paper -w)"
export IBKR_PASSWORD
exec "${IBC_HOME}/gatewaystartmacos.sh" "$@"
