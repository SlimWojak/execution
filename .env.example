# IB Gateway — paper mode (required for PAPER operating mode)
IBKR_MODE=PAPER
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=2
IBKR_FILL_TIMEOUT_SEC=30

# LIVE mode guard — never set true unless explicitly graduating to live
# IBKR_ALLOW_LIVE=false

# Integration tests / drills (optional)
# IBKR_INTEGRATION_TEST=1
